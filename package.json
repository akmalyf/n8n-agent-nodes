{
  "name": "@n8n/n8n-nodes-ai-agent",
  "version": "1.0.0",
  "description": "n8n AI Agent nodes with AI SDK integration for OpenAI and Anthropic compatible APIs",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "ai",
    "agent",
    "ai-sdk",
    "openai",
    "anthropic"
  ],
  "license": "MIT",
  "homepage": "https://github.com/your-username/n8n-nodes-ai-agent",
  "author": {
    "name": "Your Name",
    "email": "your@email.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/n8n-nodes-ai-agent.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
